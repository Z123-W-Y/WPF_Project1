<Window x:Class="Project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project"
        mc:Ignorable="d"
        Title="MainWindow"
        Loaded="MainWindow_Loaded">
    <Viewbox Stretch="Uniform">
        <!--- 标准1920*1080分辨率 电脑屏幕 用 Stretch="Uniform"（可以暂时不用管它的白边框）
              填充电脑屏幕 用 Stretch="Fill"（如果电脑不是1920*1080显示会有缩放）
        -->
        <Grid Height="1080" Width="1920">
            <!--主页面背景色-->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#243843" Offset="0.21"/>
                    <GradientStop Color="#2e4450" Offset="0.57"/>
                    <GradientStop Color="#668192" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!--行结构布局-->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--上区域-->
            <Grid Grid.Row="0">
                <!--上区域的垂直布局-->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Image Grid.Column="0" Source="/Resources/logo.png" 
                       Width="148"
                       Height="53"
                       Margin="40,22,0,0"/>

                <!--堆叠面板-->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
                    <Image  x:Name="imgAlarm" Source="/Resources/alarm1.png" VerticalAlignment="Center" 
                            Width="34" Height="34"
                            Cursor="Hand"  
                            Loaded="imgAlarm_Loaded" 
                            MouseLeftButtonDown="imgAlarm_MouseLeftButtonDown"/>
                    
                    <Line X1="0" Y1="0" X2="0" Y2="22"
                          Stroke="#FFFFFF" StrokeThickness="1"
                          Opacity="0.3" VerticalAlignment="Center"
                          Margin="18,0,18,0"/>
                    <TextBlock x:Name="txtDateTime" VerticalAlignment="Center" 
                               Text="2021-08-01 12:00:00"
                               FontSize="20" FontWeight="Medium"
                               FontFamily="Source Han Sans CN"
                               Foreground="#ffffff"
                               Margin="0,0,0,0" />
                    <Line X1="0" Y1="0" X2="0" Y2="22"
                          Stroke="#FFFFFF" StrokeThickness="1"
                          Opacity="0.3" VerticalAlignment="Center"
                          Margin="18,0,18,0"/>
                    <Image Source="/Resources/admin.png" VerticalAlignment="Center"
                           Width="34" Height="34" Margin="0,0,0,0"/>
                    <TextBlock VerticalAlignment="Center" 
                               Text="管理员"
                               FontSize="18" FontWeight="normal"
                               FontFamily="Source Han Sans CN"
                               Foreground="#ffffff"
                               Margin="10,0,0,0" />

                    <Line X1="0" Y1="0" X2="0" Y2="22"
                          Stroke="#FFFFFF" StrokeThickness="1"
                          Opacity="0.3" VerticalAlignment="Center"
                          Margin="18,0,18,0"/>
                    <Image Source="/Resources/menu.png" VerticalAlignment="Center"
                            Width="26" Height="26" Margin="0,0,28,0"/>
                </StackPanel>
            </Grid>

            <!--下区域-->
            <Grid Grid.Row="1">
                <!--垂直分区-->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!--左侧导航菜单-->
                <Border Grid.Column="0" >
                    <StackPanel Orientation="Vertical" 
                                Width="98"
                                Margin="58,42,58,0">
                        <Button x:Name="btnHome" Content="首页" Style="{StaticResource MenuButtonStyle}" 
                                Margin="0,0,0,25" Cursor="Hand"/>
                        <Line  X1="0" Y1="0" X2="1" Y2="0" Stroke="#ffffff" Opacity="0.5" 
                               StrokeThickness="1" StrokeDashArray="3,2" Stretch="Fill" 
                               Height="1"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Center" Cursor=""/>
                        <Button x:Name="btnReset" Content="复位" Style="{StaticResource MenuButtonStyle}"
                                Margin="0,26,0,0" Cursor="Hand"/>
                        <Button x:Name="btnStart" Content="启动" Style="{StaticResource MenuButtonStyle}" 
                                Margin="0,26,0,0" Cursor="Hand"/>
                        <Button x:Name="btnPause" Content="暂停" Style="{StaticResource MenuButtonStyle}" 
                                Margin="0,26,0,0" Cursor="Hand"/>
                        <Button x:Name="btnStop" Content="停止" Style="{StaticResource MenuButtonStyle}" 
                                Margin="0,26,0,24" Cursor="Hand"/>
                        <Line  X1="0" Y1="0" X2="1" Y2="0" Stroke="White" Opacity="0.5" 
                               StrokeThickness="1" StrokeDashArray="3,2" Stretch="Fill" 
                               Height="1"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Center"/>
                        <Button x:Name="btnManual" Content="手动" Style="{StaticResource MenuButtonStyle}"
                                Margin="0,26,0,0" Cursor="Hand"/>
                        <Button x:Name="btnSet" Content="设置" Style="{StaticResource MenuButtonStyle}"
                                Margin="0,26,0,55" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!--右侧内容区-->
                <Grid Grid.Column="1" >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="1" 
                          Height="40">
                        <Border Background="#243843" >
                            <TextBlock VerticalAlignment="Center" 
                                       Text="版本：1.0.0.1 | 版权所有：深圳市泰科思特精密工业有限公司 www.chinattst.com"
                                       FontSize="14" FontWeight="normal"
                                       FontFamily="Source Han Sans CN"
                                       Foreground="#ffffff"
                                       Margin="630,10,0,10" />
                        </Border>
                    </Grid>
                    <!-- 主内容容器（原ContentControl） -->
                    <ContentControl x:Name="MainContent" Grid.Row="0"/>
                </Grid>
            </Grid>
        </Grid>
    </Viewbox>
</Window>
